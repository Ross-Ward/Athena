# Athena configuration — copy to .env and fill what you use. ALL OPTIONAL:
# with none set, Athena runs in offline-deterministic mode (direct tool calls,
# no model). Add a key to unlock the full reasoning loop.

# --- Primary backend: Anthropic (recommended) ---
ANTHROPIC_API_KEY=
# Override the default model if you like:
ATHENA_ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Fallback backend: any OpenAI-compatible endpoint (OpenAI, Groq, OpenRouter,
#     LM Studio, Ollama, …). Used only if ANTHROPIC_API_KEY is unset. ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ATHENA_OPENAI_MODEL=gpt-4o-mini

# --- Behaviour ---
# Force offline mode even if keys are present: ATHENA_OFFLINE=1
ATHENA_OFFLINE=
# Max tool-use loop steps before Athena stops:
ATHENA_MAX_STEPS=8
